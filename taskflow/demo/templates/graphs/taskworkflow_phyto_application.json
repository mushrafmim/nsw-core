{
  "id": "Phyto_Application_Flow_v1",
  "name": "Phyto Sanitary Application Sub-Process",
  "version": 1,
  "nodes": [
    { "id": "start", "type": "START" },
    {
      "id": "user_submission",
      "type": "TASK",
      "task_template_id": "demo_generic_user_input",
      "input_mapping": {
        "userform": "userform"
      },
      "output_mapping": {
        "userform": "userform"
      }
    },
    {
      "id": "external_review",
      "type": "TASK",
      "task_template_id": "demo_generic_external_review",
      "input_mapping": {
        "userform": "userform"
      },
      "output_mapping": {
        "reviewerform": "reviewerform"
      }
    },
    {
      "id": "review_gateway",
      "type": "GATEWAY",
      "gateway_type": "EXCLUSIVE_SPLIT"
    },
    { "id": "end", "type": "END" }
  ],
  "edges": [
    { "id": "e1", "source_id": "start", "target_id": "user_submission" },
    { "id": "e2", "source_id": "user_submission", "target_id": "external_review" },
    { "id": "e3", "source_id": "external_review", "target_id": "review_gateway" },
    {
      "id": "e_approve",
      "source_id": "review_gateway",
      "target_id": "end",
      "condition": "reviewerform.review_outcome == 'approve'"
    },
    {
      "id": "e_reject",
      "source_id": "review_gateway",
      "target_id": "end",
      "condition": "reviewerform.review_outcome == 'reject'"
    },
    {
      "id": "e_needs_info",
      "source_id": "review_gateway",
      "target_id": "user_submission",
      "condition": "reviewerform.review_outcome == 'needs_more_info'"
    }
  ]
}
